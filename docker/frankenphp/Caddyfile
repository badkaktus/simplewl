{
    frankenphp
    debug
    auto_https off
}

:8080 {
    root * /var/www/html/public
    encode zstd br gzip

    # Serve existing static files directly
    @static file
    handle @static {
        file_server
    }

    # Everything else goes to PHP via index.php
    handle {
        rewrite * /index.php
        php_server
    }
}
